# Kopioi tämä tiedosto nimellä .env.local ja täytä omat arvosi.
# Älä koskaan tallenna .env.local versionhallintaan!

# Google Workspace / Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Google Workspace: käytä sähköpostiosoitettasi (esim. nimi@terassitalo.com)
# Gmail (@gmail.com): luo sovelluskohtainen salasana osoitteessa
#   Google-tili → Turvallisuus → 2-vaiheinen todennus → Sovellusten salasanat
SMTP_USER=lahettaja@terassitalo.com
SMTP_PASS=vaihda_tama_google_sovelluskohtaiseen_salasanaan
