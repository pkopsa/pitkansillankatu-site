{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": false
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.pitkansillankatu33.com" }],
      "destination": "https://pitkansillankatu33.com/$1",
      "permanent": true
    }
  ]
}
